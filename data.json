body {
  margin: 0;
  font-family: system-ui, sans-serif;
  background: #ffffff;
  color: #111;
}

.topbar {
  padding: 60px 20px 30px;
  text-align: center;
}

.brand {
  font-size: 34px;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.desc {
  color: #666;
  margin-top: 8px;
  font-size: 14px;
}

.container {
  max-width: 720px;
  margin: auto;
  padding: 20px;
}

/* SEARCH */
.search {
  width: 100%;
  padding: 14px 16px;
  font-size: 15px;
  border: 1px solid #ddd;
  border-radius: 10px;
  outline: none;
  margin-bottom: 30px;
}

.search:focus {
  border-color: #999;
}

/* LIST */
.list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* ITEM (NO CARD LOOK) */
.item {
  padding: 14px 0;
  border-bottom: 1px solid #eee;
  text-decoration: none;
  color: inherit;
}

.item:hover .title {
  text-decoration: underline;
}

.title {
  font-size: 17px;
  font-weight: 500;
}

.meta {
  font-size: 13px;
  color: #777;
  margin-top: 4px;
}
